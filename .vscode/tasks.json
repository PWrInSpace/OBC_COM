{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash DFU",
            "type": "shell",
            "command": "STM32_Programmer_CLI",
            "args": [
                "-c", "port=USB1",
                "-w", "${workspaceFolder}\\build\\Debug\\OBC_COM.bin", "0x08000000",
                "-v",
                "-s"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}