{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash DFU",
            "type": "shell",
            "command": "STM32_Programmer_CLI",
            "windows": {
                "command": "C:/Program Files/STMicroelectronics/STM32Cube/STM32CubeProgrammer/bin/STM32_Programmer_CLI.exe"
            },
            "args": [
                "-c", "port=usb1",
                "-w", "${workspaceFolder}/build/Debug/OBC_COM.bin", "0x08000000",
                "-v",
                "-s"
            ],
            "linux": {
                "args": [
                    "-c", "port=usb1",
                    "-w", "${workspaceFolder}/build/Debug/OBC_COM.bin", "0x08000000",
                    "-v",
                    "-s"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Serial Monitor",
            "type": "shell",
            "linux": {
                "command": "screen",
                "args": ["/dev/ttyACM0", "115200"]
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "$port= new-Object System.IO.Ports.SerialPort COM7,115200,None,8,one; $port.Open(); try { while($port.IsOpen) { Write-Host -NoNewline $port.ReadExisting() } } finally { $port.Close() }"
                ]
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}